---
// Layout.astro — Layout base del ecosistema JAH Nexus
// Incluye: CDN fonts, Bootstrap, Phosphor Icons, nexus-core.css, Navbar, Footer
// y los scripts compartidos: IntersectionObserver navbar + Scroll Reveal de tarjetas.

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/nexus-core.css';

interface Props {
  title: string;
  description: string;
  currentPage?: string;
}

const { title, description, currentPage } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Plus Jakarta Sans (Carga optimizada) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web" is:inline></script>

    <!-- Slot para estilos específicos de cada página (accent tokens) -->
    <slot name="head" />
  </head>
  <body>

    <Navbar currentPage={currentPage} />

    <main>
      <slot />
    </main>

    <Footer />

    <!-- Bootstrap 5 JS Bundle -->
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      is:inline
    ></script>

    <!-- ═══════════════════════════════════════════════════════════════
         SCRIPTS COMPARTIDOS DEL ECOSISTEMA JAH NEXUS
         1. IntersectionObserver → Navbar scrolled state (Zero thrashing)
         2. IntersectionObserver → Scroll Reveal con stagger en feature-cards
         ═══════════════════════════════════════════════════════════════ -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {

        // ─── 1. NAVBAR SCROLL STATE ──────────────────────────────────
        const nav = document.getElementById('mainNav');
        const topSentinel = document.getElementById('top-sentinel');

        if (nav && topSentinel && 'IntersectionObserver' in window) {
          const navObserver = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (!entry.isIntersecting) {
                nav.classList.add('navbar-scrolled');
              } else {
                nav.classList.remove('navbar-scrolled');
              }
            });
          }, { threshold: 0 });
          navObserver.observe(topSentinel);
        } else if (nav) {
          // Fallback pasivo para navegadores legacy
          window.addEventListener('scroll', function () {
            nav.classList.toggle('navbar-scrolled', window.scrollY > 50);
          }, { passive: true });
        }

        // ─── 2. SCROLL REVEAL CON STAGGER EN FEATURE CARDS ───────────
        const cards = document.querySelectorAll('.feature-card');

        if ('IntersectionObserver' in window && cards.length > 0) {
          const revealObserver = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                revealObserver.unobserve(entry.target); // Sólo se anima una vez
              }
            });
          }, {
            threshold: 0.1,       // Dispara cuando el 10% de la tarjeta es visible
            rootMargin: '0px 0px -40px 0px' // Pequeño delay antes del borde inferior
          });

          cards.forEach(function (card, index) {
            // Stagger delay: cada tarjeta espera 80ms más que la anterior
            card.style.transitionDelay = (index % 4) * 80 + 'ms';
            revealObserver.observe(card);
          });
        } else {
          // Fallback: mostrar todas las tarjetas inmediatamente
          cards.forEach(function (card) {
            card.classList.add('is-visible');
          });
        }

      });
    </script>

  </body>
</html>
