---
// Navbar.astro — Componente compartido del ecosistema JAH Nexus
// Props: currentPage - identifica la página activa para el estado 'active'
interface Props {
  currentPage?: string;
}
const { currentPage = '' } = Astro.props;

const WA_URL = "https://wa.me/524493134110?text=Hola,%20me%20interesa%20agendar%20una%20llamada%20estrat%C3%A9gica%20para%20conocer%20m%C3%A1s%20sobre%20JAH%20Nexus.";

const isEcosistemPage = ['sentinel','noc','central','paycontrol','zabbix','netbox'].includes(currentPage);
---

<!-- Sentinel invisible para el IntersectionObserver del navbar -->
<div class="top-sentinel" id="top-sentinel" aria-hidden="true"></div>

<nav class="navbar navbar-expand-lg fixed-top" id="mainNav" aria-label="Navegación principal de JAH Nexus">
  <div class="container">
    <a class="navbar-brand" href="/">
      <i class="ph-fill ph-graph logo-icon" aria-hidden="true"></i>
      JAH <span class="logo-wordmark">NEXUS</span>
    </a>
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav"
      aria-controls="navbarNav"
      aria-expanded="false"
      aria-label="Abrir menú de navegación"
    >
      <i class="ph ph-list toggler-icon" aria-hidden="true"></i>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
        <li class="nav-item">
          <a class={`nav-link ${currentPage === 'index' ? 'active' : ''}`} href="/">
            Inicio
          </a>
        </li>
        <li class="nav-item">
          <a class={`nav-link ${currentPage === 'manual' ? 'active' : ''}`} href="/manual">
            Manual
          </a>
        </li>
        <li class="nav-item dropdown">
          <a
            class={`nav-link dropdown-toggle ${isEcosistemPage ? 'active' : ''}`}
            href="#ecosistema"
            role="button"
            data-bs-toggle="dropdown"
            aria-expanded="false"
          >
            Ecosistema
          </a>
          <ul class="dropdown-menu dropdown-menu-dark">
            <li>
              <a class={`dropdown-item ${currentPage === 'sentinel' ? 'is-active' : ''}`} href="/sentinel">
                JAH Sentinel
              </a>
            </li>
            <li>
              <a class={`dropdown-item ${currentPage === 'noc' ? 'is-active' : ''}`} href="/noc">
                Jah-NOC
              </a>
            </li>
            <li>
              <a class={`dropdown-item ${currentPage === 'central' ? 'is-active' : ''}`} href="/central">
                Jah Central
              </a>
            </li>
            <li>
              <a class={`dropdown-item ${currentPage === 'paycontrol' ? 'is-active' : ''}`} href="/paycontrol">
                JahPayControl
              </a>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
              <a class={`dropdown-item ${currentPage === 'zabbix' ? 'is-active' : ''}`} href="/zabbix">
                Telemetría Zabbix
              </a>
            </li>
            <li>
              <a class={`dropdown-item ${currentPage === 'netbox' ? 'is-active' : ''}`} href="/netbox">
                DCIM NetBox
              </a>
            </li>
          </ul>
        </li>
        <li class="nav-item ms-lg-3 mt-3 mt-lg-0">
          <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="btn-brand text-decoration-none">
            Agendar llamada
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>
